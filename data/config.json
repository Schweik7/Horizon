{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "量子位",
        "url": "https://wechat2rss.xlab.app/feed/7131b577c61365cb47e81000738c10d872685908.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "新智元",
        "url": "https://wechat2rss.xlab.app/feed/ede30346413ea70dbef5d485ea5cbb95cca446e7.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "tech-science"
      },
      {
        "name": "Ars Technica - Science",
        "url": "https://feeds.arstechnica.com/arstechnica/science",
        "enabled": true,
        "category": "science"
      },
      {
        "name": "New Scientist",
        "url": "https://www.newscientist.com/feed/home/",
        "enabled": true,
        "category": "science"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        },
        {
          "subreddit": "Futurology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 200
        },
        {
          "subreddit": "science",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 1000
        },
        {
          "subreddit": "InternetIsBeautiful",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 300
        }
      ],
      "users": [],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "score_context": "Score cybersecurity, vulnerabilities, CVEs, exploits, security patches, and hacking-related content 0-2 unless it is directly relevant to an AI or interesting application breakthrough. Boost scores for content about creative AI applications, fun tools, and speculative or futuristic scientific ideas."
  },
  "webhook": {
    "enabled": false
  }
}
